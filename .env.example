# Compose-level defaults shared by default, dev, and test profile workflows.
# Copy to .env and adjust values per environment.

# Profile selection (optional). Examples: dev, test, or dev,test
COMPOSE_PROFILES=

# Service port mappings (host -> container)
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Database settings used by db and backend services
POSTGRES_DB=todo
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo

# Optional full override for backend DB connection string.
# If empty, compose builds it from POSTGRES_* values.
DATABASE_URL=

# Backend CORS for compose-hosted frontend access
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Frontend build-time API base URL used in compose image builds
VITE_API_BASE_URL=/api
